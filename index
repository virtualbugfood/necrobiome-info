<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NECROBIOME // CELL-SIM v0.25</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cyan:    #00FFB4;
    --pink:    #FF3296;
    --blue:    #00C8FF;
    --violet:  #CC00FF;
    --lime:    #64FF00;
    --silver:  #C8C8C8;
    --bg:      #02020C;
    --surface: #05050F;
    --border:  #1A1A3A;
    --dim:     #7AAFA0;
    --dimmer:  #5A8878;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--cyan);
    font-family: 'Share Tech Mono', 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.7;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 999;
  }

  /* Particle canvas */
  #particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 1;
  }

  .page {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  /* в”Җв”Җ Hero в”Җв”Җ */
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }

  .banner-wrap {
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .banner {
    font-family: 'VT323', monospace;
    font-size: clamp(6px, 1.05vw, 13px);
    line-height: 1.15;
    color: var(--cyan);
    white-space: pre;
    display: inline-block;
    text-align: left;
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { text-shadow: 0 0 8px rgba(0,255,180,0.3); }
    50%       { text-shadow: 0 0 20px rgba(0,255,180,0.6), 0 0 40px rgba(0,255,180,0.2); }
  }

  .subtitle {
    color: var(--pink);
    letter-spacing: 4px;
    font-size: 12px;
    margin-bottom: 0.4rem;
    animation: fadeup 1s ease 0.3s both;
  }

  .tagline {
    color: var(--dim);
    font-style: italic;
    font-size: 13px;
    animation: fadeup 1s ease 0.5s both;
  }

  @keyframes fadeup {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }

  .install-strip {
    margin: 2rem auto 0;
    display: inline-block;
    background: #080814;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    font-size: 13px;
    color: var(--blue);
    letter-spacing: 1px;
    animation: fadeup 1s ease 0.7s both;
  }

  .install-strip span { color: var(--dim); margin: 0 0.5rem; }

  /* в”Җв”Җ Section headers в”Җв”Җ */
  .section-label {
    color: var(--pink);
    font-size: 11px;
    letter-spacing: 3px;
    margin: 3.5rem 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }

  /* в”Җв”Җ Intro text в”Җв”Җ */
  .intro {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem 2rem;
    animation: fadeup 1s ease 0.9s both;
  }

  .intro p { color: var(--dim); line-height: 1.9; }
  .intro p + p { margin-top: 0.75rem; }
  .intro .hi { color: var(--cyan); }
  .intro .hi2 { color: var(--blue); }

  /* в”Җв”Җ Biome grid в”Җв”Җ */
  .biome-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 8px;
  }

  .biome-card {
    background: var(--surface);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s, transform 0.2s;
    cursor: default;
  }
  .biome-card:hover {
    transform: translateY(-2px);
  }
  .biome-card.void    { border-color: #001A10; }
  .biome-card.neon    { border-color: #200015; }
  .biome-card.reef    { border-color: #001525; }
  .biome-card.chrome  { border-color: #222222; }
  .biome-card.acid    { border-color: #0D1A00; }
  .biome-card.cyber   { border-color: #2A005A; background: #0D0020; }

  .biome-card:hover.void   { border-color: #00FFB4; }
  .biome-card:hover.neon   { border-color: #FF3296; }
  .biome-card:hover.reef   { border-color: #00C8FF; }
  .biome-card:hover.chrome { border-color: #C8C8C8; }
  .biome-card:hover.acid   { border-color: #64FF00; }
  .biome-card:hover.cyber  { border-color: #CC00FF; }

  .biome-name {
    font-size: 11px;
    letter-spacing: 2px;
    margin-bottom: 0.4rem;
  }
  .biome-desc { color: var(--dimmer); font-size: 11px; line-height: 1.6; }

  /* в”Җв”Җ Systems grid в”Җв”Җ */
  .systems-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 520px) { .systems-grid { grid-template-columns: 1fr; } }

  .system-item h3 {
    color: var(--cyan);
    font-size: 13px;
    margin-bottom: 0.3rem;
    font-weight: normal;
  }
  .system-item p { color: var(--dimmer); font-size: 11px; line-height: 1.6; }

  /* в”Җв”Җ Titles list в”Җв”Җ */
  .titles-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid #0A0A1A;
  }
  .title-badge {
    font-size: 11px;
    color: var(--cyan);
    min-width: 120px;
    flex-shrink: 0;
  }
  .title-desc { color: var(--dimmer); font-size: 11px; }
  .perm { color: var(--pink); font-size: 10px; margin-left: 6px; }

  /* в”Җв”Җ Modes в”Җв”Җ */
  .modes-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mode-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .mode-icon {
    font-size: 13px;
    min-width: 130px;
    flex-shrink: 0;
  }
  .mode-desc { color: var(--dimmer); font-size: 11px; line-height: 1.6; }

  /* в”Җв”Җ Controls в”Җв”Җ */
  .controls-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 6px 1.5rem;
  }
  .ctrl-row {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
  }
  .ctrl-key {
    color: var(--cyan);
    font-size: 11px;
    min-width: 80px;
    flex-shrink: 0;
  }
  .ctrl-action { color: var(--dimmer); font-size: 11px; }

  /* в”Җв”Җ Card wrapper в”Җв”Җ */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem 2rem;
  }

  /* в”Җв”Җ Footer в”Җв”Җ */
  footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
    color: #0E1E18;
    font-size: 11px;
    line-height: 2;
  }
  footer a { color: var(--dim); text-decoration: none; }
  footer a:hover { color: var(--cyan); }

  /* в”Җв”Җ Ticker в”Җв”Җ */
  .ticker-wrap {
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: #030310;
    padding: 0.4rem 0;
    margin: 2rem 0;
    position: relative;
  }
  .ticker-track {
    display: inline-block;
    white-space: nowrap;
    animation: ticker 30s linear infinite;
    color: var(--pink);
    font-size: 11px;
    letter-spacing: 1px;
  }
  @keyframes ticker {
    from { transform: translateX(100vw); }
    to   { transform: translateX(-100%); }
  }
</style>
</head>
