  <p class="section-label">AVAILABILITY</p>
  <div class="card" style="text-align: center; padding: 2.5rem 2rem;">
    <p style="color: var(--pink); font-size: 13px; letter-spacing: 3px; margin-bottom: 0.75rem;">// COMING SOON //</p>
    <p style="color: var(--dim); font-size: 12px; line-height: 1.9;">
      NECROBIOME is currently in active development.<br>
      More information will be available here when it's ready.
    </p>
  </div>

  <!-- Footer -->
  <footer>
    <p>NECROBIOME is an open simulation. It does not have a win state.</p>
    <p>It has only the next tick. And the tick after that.</p>
    <p>And whatever emerges from the space between them.</p>
  </footer>

</div>

<script>
const canvas = document.getElementById('particles');
const ctx = canvas.getContext('2d');
const chars = '.В·:,~-+*@#%';
const particles = [];

function resize() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

for (let i = 0; i < 80; i++) {
  particles.push({
    x:  Math.random(),
    y:  Math.random(),
    vx: (Math.random() - 0.5) * 0.0002,
    vy: (Math.random() - 0.5) * 0.0002,
    ch: chars[Math.floor(Math.random() * chars.length)],
    br: Math.random() * 0.25 + 0.12,
  });
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.font = '11px "Share Tech Mono", monospace';
  for (const p of particles) {
    p.x = (p.x + p.vx + 1) % 1;
    p.y = (p.y + p.vy + 1) % 1;
    const v = Math.floor(p.br * 255);
    // Mix of cyan-green and pink-magenta tones
    const hue = Math.random() > 0.8 ? `rgb(${v},${Math.floor(v*0.2)},${Math.floor(v*0.6)})` : `rgb(0,${v},${Math.floor(v*0.7)})`;
    ctx.fillStyle = hue;
    ctx.fillText(p.ch, p.x * canvas.width, p.y * canvas.height);
  }
  requestAnimationFrame(draw);
}
draw();

// Stagger biome card animations
document.querySelectorAll('.biome-card').forEach((el, i) => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(16px)';
  el.style.transition = `opacity 0.5s ease ${0.1 + i * 0.08}s, transform 0.5s ease ${0.1 + i * 0.08}s, border-color 0.2s, box-shadow 0.2s`;
  setTimeout(() => {
    el.style.opacity = '1';
    el.style.transform = 'none';
  }, 100 + i * 80);
});
</script>
</body>
</html>
